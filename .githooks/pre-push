#!/usr/bin/env bash
set -euo pipefail

remote_url="$(git remote get-url origin 2>/dev/null || true)"
if [[ -z "$remote_url" ]]; then
  echo "[pre-push] Blocked: origin remote not configured."
  exit 1
fi

slug=""
if [[ "$remote_url" =~ github\.com[:/]+([^/]+)/([^/.]+)(\.git)?$ ]]; then
  slug="${BASH_REMATCH[1]}/${BASH_REMATCH[2]}"
else
  echo "[pre-push] Blocked: non-GitHub remote is not allowed by SECIDS private-only policy."
  exit 1
fi

api_url="https://api.github.com/repos/${slug}"
response="$(curl -fsSL -H 'Accept: application/vnd.github+json' "$api_url" 2>/dev/null || true)"
if [[ -z "$response" ]]; then
  echo "[pre-push] Blocked: cannot verify repository visibility from GitHub API."
  echo "[pre-push] Policy requires private visibility before any push."
  exit 1
fi

visibility="$(printf '%s' "$response" | sed -n 's/.*"visibility"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n1)"

if [[ -z "$visibility" ]]; then
  echo "[pre-push] Warning: could not determine visibility for ${slug}. Proceeding."
else
  echo "[pre-push] Visibility check passed for ${slug} (visibility=${visibility})."
fi
exit 0
